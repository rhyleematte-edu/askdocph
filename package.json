{
    "private": true,
    "scripts": {
        "dev": "npm run development",
        "development": "mix",
        "watch": "mix watch",
        "watch-poll": "mix watch -- --watch-options-poll=1000",
        "hot": "mix watch --hot",
        "prod": "npm run production",
        "production": "mix --production",
        "build": "composer install --no-dev --optimize-autoloader && npm run production && php artisan config:clear && php artisan cache:clear && php artisan view:clear && php artisan migrate --force",
        "start": "php artisan serve --host=0.0.0.0 --port=$PORT"
    },
    "dependencies": {
        "axios": "^0.21",
        "laravel-mix": "^6.0.6",
        "lodash": "^4.17.19",
        "postcss": "^8.1.14"
    },
    "devDependencies": {
        "facade/ignition": "^2.5",

    }
}
